import random

# Crear tablero
tablero = [[" " for _ in range(3)] for _ in range(3)]

# Mostrar tablero
def mostrar():
    print("\n")
    for fila in tablero:
        print(" | ".join(fila))
        print("-" * 9)

# Verificar ganador
def verificar(jugador):
    # Filas
    for fila in tablero:
        if all(celda == jugador for celda in fila):
            return True

    # Columnas
    for col in range(3):
        if all(tablero[fila][col] == jugador for fila in range(3)):
            return True

    # Diagonal principal
    if all(tablero[i][i] == jugador for i in range(3)):
        return True

    # Diagonal secundaria
    if all(tablero[i][2 - i] == jugador for i in range(3)):
        return True

    return False

# Verificar empate
def empate():
    return all(tablero[f][c] != " " for f in range(3) for c in range(3))

# Convertir posición 1-9 a coordenadas
def convertir(pos):
    fila = (pos - 1) // 3
    col = (pos - 1) % 3
    return fila, col

# Turno humano
def turno_humano():
    while True:
        try:
            pos = int(input("Elige una posición (1-9): "))
            if pos < 1 or pos > 9:
                print("Posición inválida")
                continue

            fila, col = convertir(pos)

            if tablero[fila][col] == " ":
                tablero[fila][col] = "X"
                break
            else:
                print("Esa posición ya está ocupada")

        except:
            print("Entrada inválida")

# Turno computadora
def turno_pc():
    print("Turno de la computadora...")
    libres = [(f, c) for f in range(3) for c in range(3) if tablero[f][c] == " "]
    fila, col = random.choice(libres)
    tablero[fila][col] = "O"

# Juego principal
def jugar():
    mostrar()

    while True:
        turno_humano()
        mostrar()

        if verificar("X"):
            print("✅ Gana el humano")
            break

        if empate():
            print("⚖️ Nadie ganó")
            break

        turno_pc()
        mostrar()

        if verificar("O"):
            print("🤖 Gana la computadora")
            break

        if empate():
            print("⚖️ Nadie ganó")
            break


# Ejecutar
jugar()
